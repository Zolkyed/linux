# Kitty-equivalent Ghostty configuration

# Font
font-family = JetBrains Mono Nerd Font

# Catppuccin Mocha
foreground = #cdd6f4
background = #1e1e2e
selection-foreground = #cdd6f4
selection-background = #353749
cursor-color = #f5e0dc
cursor-text = #11111b

palette = 0=#45475a
palette = 1=#f38ba8
palette = 2=#a6e3a1
palette = 3=#f9e2af
palette = 4=#89b4fa
palette = 5=#f5c2e7
palette = 6=#94e2d5
palette = 7=#a6adc8
palette = 8=#585b70
palette = 9=#f38ba8
palette = 10=#a6e3a1
palette = 11=#f9e2af
palette = 12=#89b4fa
palette = 13=#f5c2e7
palette = 14=#94e2d5
palette = 15=#bac2de

# Appearance
maximize = true
gtk-single-instance = true

# Functionality
scrollback-limit = 10000
copy-on-select = true
clipboard-trim-trailing-spaces = true
app-notifications = no-clipboard-copy,config-reload
shell-integration = detect
confirm-close-surface = false

# Keybinds
keybind = ctrl+shift+l=clear_screen

# Font size
keybind = ctrl+equal=increase_font_size:1
keybind = ctrl+shift+equal=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+shift+minus=decrease_font_size:1
keybind = ctrl+0=reset_font_size
keybind = ctrl+shift+0=reset_font_size

# Tabs
keybind = ctrl+t=new_tab
keybind = ctrl+w=close_tab:this
keybind = ctrl+arrow_left=previous_tab
keybind = ctrl+arrow_right=next_tab
keybind = ctrl+1=goto_tab:1
keybind = ctrl+2=goto_tab:2
keybind = ctrl+3=goto_tab:3
keybind = ctrl+4=goto_tab:4
keybind = ctrl+5=goto_tab:5
keybind = ctrl+6=goto_tab:6
keybind = ctrl+7=goto_tab:7
keybind = ctrl+8=goto_tab:8
keybind = ctrl+9=goto_tab:9

# Splits
keybind = alt+minus=new_split:down
keybind = alt+backslash=new_split:right
keybind = alt+w=close_surface
keybind = alt+arrow_left=goto_split:left
keybind = alt+arrow_right=goto_split:right
keybind = alt+arrow_up=goto_split:up
keybind = alt+arrow_down=goto_split:down
