{
  "app_config": {
    "audio_config": {
      "audio": "pipewire"
    },
    "bluetooth_config": {
      "enabled": true
    },
    "firewall_config": {
      "firewall": "ufw"
    }
  },
  "bootloader_config": {
    "bootloader": "Limine",
    "removable": false,
    "uki": false
  },
  "hostname": "archlinux",
  "kernels": [
    "linux-lts"
  ],
  "locale_config": {
    "kb_layout": "us",
    "sys_enc": "UTF-8",
    "sys_lang": "en_US.UTF-8"
  },
  "mirror_config": {
    "mirror_regions": {
      "Canada": [],
      "United States": []
    },
    "optional_repositories": [
      "multilib"
    ]
  },
  "network_config": {
    "type": "nm"
  },
  "ntp": true,
  "packages": [
    "base-devel",
    "git",
    "networkmanager",
    "sudo",
    "inetutils"
  ],
  "pacman_config": {
    "color": true
  },
  "services": [
    "NetworkManager.service"
  ],
  "swap": {
    "algorithm": "zstd",
    "enabled": true
  },
  "timezone": "America/Toronto",
  "version": "4.3"
}
